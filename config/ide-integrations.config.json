{
  "integrations": [
    {
      "name": "VS Code",
      "integration_type": "extension_bridge",
      "protocol": "WebSocket",
      "port": 3100,
      "compatible_agents": ["Claude Code", "Codex", "OpenCode"],
      "config": {
        "ws_endpoint": "ws://localhost:3100/vscode",
        "auto_connect": true,
        "reconnect_interval_ms": 5000
      }
    },
    {
      "name": "Cline",
      "integration_type": "cli_bridge",
      "protocol": "Local Process",
      "compatible_agents": ["Claude Code", "Codex"],
      "config": {
        "pipe_mode": "stdio",
        "command": "node agents/cline-cli/bridge.js"
      }
    },
    {
      "name": "Roo Code",
      "integration_type": "extension_bridge",
      "protocol": "HTTP + WebSocket",
      "port": 3101,
      "compatible_agents": ["Codex"],
      "config": {
        "http_endpoint": "http://localhost:3101/roo",
        "ws_endpoint": "ws://localhost:3101/roo/ws"
      }
    },
    {
      "name": "JetBrains",
      "integration_type": "plugin_bridge",
      "protocol": "HTTP Gateway",
      "port": 3102,
      "compatible_agents": ["Claude Code", "Codex"],
      "config": {
        "http_endpoint": "http://localhost:3102/jetbrains",
        "auth_required": false
      }
    },
    {
      "name": "Xcode",
      "integration_type": "plugin_bridge",
      "protocol": "Local Gateway",
      "port": 3103,
      "compatible_agents": ["Claude Code"],
      "config": {
        "gateway_endpoint": "http://localhost:3103/xcode"
      }
    },
    {
      "name": "Zed",
      "integration_type": "extension_bridge",
      "protocol": "WebSocket",
      "port": 3104,
      "compatible_agents": ["Codex", "OpenCode"],
      "config": {
        "ws_endpoint": "ws://localhost:3104/zed"
      }
    }
  ]
}
