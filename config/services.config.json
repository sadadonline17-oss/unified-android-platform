{
  "services": {
    "ollama": {
      "name": "Ollama Model Server",
      "command": "ollama serve",
      "port": 11434,
      "auto_start": true,
      "auto_restart_on_crash": true,
      "health_check": "http://localhost:11434/api/tags",
      "restart_delay_ms": 3000,
      "max_restarts": 5
    },
    "n8n": {
      "name": "n8n Workflow Engine",
      "command": "n8n start",
      "port": 5678,
      "auto_start": true,
      "auto_restart_on_crash": true,
      "health_check": "http://localhost:5678/healthz",
      "restart_delay_ms": 5000,
      "max_restarts": 3,
      "env": {
        "N8N_HOST": "0.0.0.0",
        "N8N_PORT": "5678",
        "N8N_PROTOCOL": "http"
      }
    },
    "nullclaw_gateway": {
      "name": "NullClaw API Gateway",
      "command": "node backend/gateway/index.js",
      "port": 3000,
      "auto_start": true,
      "auto_restart_on_crash": true,
      "health_check": "http://localhost:3000/health",
      "restart_delay_ms": 2000,
      "max_restarts": 10
    }
  },
  "daemon": {
    "pid_file": "/tmp/unified-platform-daemon.pid",
    "log_file": "./logs/daemon.log",
    "check_interval_ms": 10000
  },
  "commands": [
    "install_agent",
    "remove_agent",
    "start_agent",
    "stop_agent",
    "restart_agent",
    "status_agent",
    "view_logs"
  ]
}
